# Google Tag Manager ID (format: GTM-XXXXXX)
NEXT_PUBLIC_GTM=

# The URL where your application is hosted (e.g., https://your-portfolio.com)
NEXT_PUBLIC_APP_URL=

# Telegram Bot Token from BotFather (for contact form notifications)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID to receive notifications
TELEGRAM_CHAT_ID=

# App password for Gmail (for sending emails via SMTP)
GMAIL_PASSKEY=

# Your email address for sending notifications
EMAIL_ADDRESS="prathampatil7798@gmail.com"

# Used for EmailJS integration
NEXT_PUBLIC_EMAILJS_SERVICE_ID="service_9i46eu5"
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_OWNER="template_7cvpktb"
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID_USER="template_rywf16e"
NEXT_PUBLIC_EMAILJS_USER_ID="service_9i46eu5"


# Google reCAPTCHA integration
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Optional configurations (if needed)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com